# Copy to .env and edit:  cp .env.example .env

# --- DGX Spark target -------------------------------------------------------
# IP or hostname of the DGX, reachable from wherever Prometheus runs.
DGX_HOST=192.168.1.50

# Friendly name shown as the Grafana $instance value (no spaces). All scrape jobs
# are tagged with this so one variable drives every panel.
DGX_NAME=dgx-spark

# --- Grafana ----------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme
